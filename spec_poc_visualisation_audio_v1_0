### 3.3 Helper concat alignment

```python
def merge_alignments_with_offset(chunk_alignments, chunk_durations_sec):
    """
    Concatène les alignments de tous les chunks en offsetant les timestamps.

    chunk_alignments : list de dicts (1 par chunk)
    chunk_durations_sec : list de durées en secondes (1 par chunk)

    Retourne un dict aligné sur l'audio total concaténé.
    """
    merged = {
        "characters": [],
        "character_start_times_seconds": [],
        "character_end_times_seconds": [],
    }

    cumulative_offset = 0.0
    for alignment, duration in zip(chunk_alignments, chunk_durations_sec):
        merged["characters"].extend(alignment["characters"])
        merged["character_start_times_seconds"].extend(
            t + cumulative_offset for t in alignment["character_start_times_seconds"]
        )
        merged["character_end_times_seconds"].extend(
            t + cumulative_offset for t in alignment["character_end_times_seconds"]
        )
        cumulative_offset += duration

    return merged


def chunk_duration_from_alignment(alignment):
    """Dérive la durée d'un chunk depuis son alignment (dernier timestamp end)."""
    if not alignment["character_end_times_seconds"]:
        return 0.0
    return alignment["character_end_times_seconds"][-1]
```

### 3.4 Helper words depuis characters

```python
def characters_to_words(merged_alignment, original_script_text):
    """
    Regroupe les caractères en mots par split sur espace + ponctuation.
    Retourne une liste de words avec start/end timestamps.
    """
    words = []
    current_word_chars = []
    current_word_start = None

    for i, char in enumerate(merged_alignment["characters"]):
        char_start = merged_alignment["character_start_times_seconds"][i]
        char_end = merged_alignment["character_end_times_seconds"][i]

        if char in (" ", "\n", "\t"):
            # Fin de mot
            if current_word_chars:
                words.append({
                    "text": "".join(current_word_chars),
                    "start_sec": current_word_start,
                    "end_sec": prev_char_end,
                })
                current_word_chars = []
                current_word_start = None
        else:
            if not current_word_chars:
                current_word_start = char_start
            current_word_chars.append(char)
            prev_char_end = char_end

    # Dernier mot
    if current_word_chars:
        words.append({
            "text": "".join(current_word_chars),
            "start_sec": current_word_start,
            "end_sec": prev_char_end,
        })

    return words
```

