## 2. Format JSON timeline universel

### 2.1 Schéma TypeScript

Format unique pour formations ET news (champs optionnels selon le type).

```typescript
interface Timeline {
  // Métadonnées générales
  schema_version: '1.0';
  source_type: 'formation_sequence' | 'news_synthesis';
  source_id: string;                    // sequence.id ou news_syntheses.id
  audio_url: string;
  duration_sec: number;
  generated_at: string;                 // ISO 8601
  generator: 'auto_python_pipeline' | 'auto_llm_extraction' | 'manual_admin_edit';

  // Niveau 1 — transcript (FORMATIONS uniquement, NULL pour news)
  transcript?: {
    segments: Array<{
      start_sec: number;
      end_sec: number;
      speaker: 'sophie' | 'martin';
      text: string;
      words: Array<{
        start_sec: number;
        end_sec: number;
        text: string;
      }>;
    }>;
  };

  // Niveau 1 — concepts surimprimés (formations + news)
  concepts?: Array<{
    at_sec?: number;                    // formations : timestamp précis
    at_word_index?: number;             // formations : index mot dans transcript.segments[].words
    term: string;                       // ex : "syndrome de la dent fêlée"
    definition: string;                 // ex : "Fracture incomplète d'une dent vivante..."
    source?: string;                    // optionnel : "Wikipédia" / "Larousse Médical" / "généré"
  }>;

  // Niveau 2A — scènes whiteboard structurées
  scenes: Array<Scene>;

  // Chapitrage (optionnel, généré automatiquement depuis les titres de scenes)
  chapters?: Array<{
    at_sec: number;
    title: string;
  }>;
}

// Scène = un template + son contenu + son timing
type Scene = {
  id: string;                           // uuid stable, permet édition
  title: string;                        // 3-6 mots, sentence case
  template: SceneTemplate;
  trigger_at_sec: number;               // formations : timestamp précis ; news : ignoré (défilement auto)
  display_duration_sec: number;         // formations : durée d'affichage avant masquage ; news : durée fixe avant scène suivante
  pedagogical_intent?: string;          // pour debug/édition humaine, pas affiché user
};

type SceneTemplate =
  | { kind: 'flowchart';  steps: Array<CardContent>;       orientation: 'horizontal' | 'vertical' }
  | { kind: 'grid';       cards: Array<CardContent>;       cols: 2 | 3 | 4 }
  | { kind: 'comparison'; left: CardContent;               right: CardContent }
  | { kind: 'causal';     nodes: Array<CardContent>;       edges: Array<{ from: string; to: string; label?: string }> }
  | { kind: 'figures';    items: Array<{ value: string; label: string; emphasis?: boolean }> }
  | { kind: 'timeline';   events: Array<{ at_label: string; text: string }> };

interface CardContent {
  id: string;                           // unique dans la scène, sert pour edges
  text: string;                         // ≤60 caractères (enforcé)
  subtitle?: string;                    // ≤40 caractères
  variant?: 'default' | 'highlight' | 'warning' | 'success';
}
```

