### 3.D — API publique journal (côté utilisateur)

**Fichier à créer** : `src/app/api/news/journal/current/route.ts`

```typescript
export const dynamic = 'force-dynamic';

// GET — retourne le journal publié le plus récent
// Auth : authenticated (createAdminClient pour bypass RLS — même pattern /api/news/syntheses)
// Si aucun journal publié → 404

export async function GET() {
  const adminClient = createAdminClient();

  const { data, error } = await adminClient
    .from('news_episodes')
    .select(`
      id,
      week_iso,
      audio_url,
      duration_s,
      status,
      created_at,
      news_episode_syntheses (
        position,
        news_syntheses (
          display_title,
          specialite,
          summary_fr,
          clinical_impact,
          key_figures,
          evidence_level,
          news_raw (
            source_url,
            journal_name
          )
        )
      )
    `)
    .eq('type', 'journal')
    .eq('status', 'published')
    .order('created_at', { ascending: false })
    .limit(1)
    .single();

  if (error || !data) {
    return NextResponse.json(null, { status: 404 });
  }

  // Aplatir news_episode_syntheses pour un retour propre
  const syntheses = (data.news_episode_syntheses ?? [])
    .sort((a, b) => a.position - b.position)
    .map(nes => ({
      position: nes.position,
      ...nes.news_syntheses,
      source_url: nes.news_syntheses?.news_raw?.source_url ?? null,
      journal_name: nes.news_syntheses?.news_raw?.journal_name ?? null,
    }));

  return NextResponse.json({ ...data, syntheses });
}
```

